{
  "name": "avalanche-subnet-cli",
  "version": "1.0.1",
  "description": "Interactive CLI wizard for Avalanche subnet creation and management",
  "main": "subnet-wizard.js",
  "bin": {
    "subnet-wizard": "subnet-wizard.js"
  },
  "scripts": {
    "start": "node subnet-wizard.js",
    "create": "node subnet-wizard.js create",
    "list": "node subnet-wizard.js list",
    "test": "jest",
    "prepublishOnly": "node -e \"console.log('✅ Ready to publish avalanche-subnet-cli v' + require('./package.json').version)\""
  },
  "keywords": [
    "avalanche",
    "subnet",
    "blockchain",
    "cli",
    "wizard",
    "evm",
    "web3",
    "cryptocurrency",
    "fuji",
    "testnet"
  ],
  "author": "Rohan Singh <rohansingh3001@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rohansingh3001/Avlanche-1.git"
  },
  "homepage": "https://github.com/Rohansingh3001/Avlanche-1#readme",
  "bugs": {
    "url": "https://github.com/Rohansingh3001/Avlanche-1/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "subnet-wizard.js",
    "utils/",
    "examples/",
    "install.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "inquirer": "^8.2.5",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "fs-extra": "^11.1.1",
    "yargs": "^17.7.2",
    "axios": "^1.4.0",
    "moment": "^2.29.4"
  },
  "devDependencies": {
    "jest": "^29.5.0"
  }
}
